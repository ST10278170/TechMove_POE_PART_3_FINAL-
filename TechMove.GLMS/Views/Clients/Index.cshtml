@model TechMove.GLMS.Helpers.PaginatedList<TechMove.GLMS.API.Models.Client>


@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2>Clients</h2>

    <a class="btn btn-primary" asp-action="Create">Create New Client</a>
</div>

<!-- Search Bar -->
<form method="get" asp-action="Index" class="mb-3">
    <div class="input-group">
        <input type="text" name="searchTerm" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search clients..." />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </div>
</form>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSort"]" class="text-white">Name</a>
            </th>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["ContactSort"]" class="text-white">Contact Person</a>
            </th>
            <th>Email</th>
            <th>Phone</th>
            <th>Region</th>
            <th style="width: 180px;"></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.ContactPerson</td>
                <td>@client.Email</td>
                <td>@client.Phone</td>
                <td>@client.Region</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination Controls -->
<nav aria-label="Page navigation">
    <ul class="pagination">

        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex - 1)"
               asp-route-searchTerm="@ViewData["CurrentFilter"]"
               asp-route-sortOrder="@ViewData["CurrentSort"]">
                Previous
            </a>
        </li>

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@i"
                   asp-route-searchTerm="@ViewData["CurrentFilter"]"
                   asp-route-sortOrder="@ViewData["CurrentSort"]">
                    @i
                </a>
            </li>
        }

        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" asp-action="Index"
               asp-route-pageNumber="@(Model.PageIndex + 1)"
               asp-route-searchTerm="@ViewData["CurrentFilter"]"
               asp-route-sortOrder="@ViewData["CurrentSort"]">
                Next
            </a>
        </li>

    </ul>
</nav>
