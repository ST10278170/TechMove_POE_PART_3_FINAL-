@model TechMove.GLMS.API.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">

        <h3 class="mb-3">Edit Contract</h3>
        <hr />

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="alert alert-danger"></div>

            <!-- Hidden Fields -->
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <!-- Contract Number -->
            <div class="form-group mb-3">
                <label asp-for="ContractNumber" class="form-label"></label>
                <input asp-for="ContractNumber" class="form-control" />
                <span asp-validation-for="ContractNumber" class="text-danger"></span>
            </div>

            <!-- Client Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="ClientId" class="form-label">Client</label>
                <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-control">
                    <option value="">-- Select Client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <!-- Start Date -->
            <div class="form-group mb-3">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <!-- End Date -->
            <div class="form-group mb-3">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <!-- Status Dropdown -->
            <div class="form-group mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="ViewBag.Status" class="form-control"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <!-- Service Level -->
            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="form-label"></label>
                <input asp-for="ServiceLevel" class="form-control" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>

            <!-- Base Rate -->
            <div class="form-group mb-3">
                <label asp-for="BaseRate" class="form-label"></label>
                <input asp-for="BaseRate" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="BaseRate" class="text-danger"></span>
            </div>

            <!-- Penalty Rate -->
            <div class="form-group mb-3">
                <label asp-for="PenaltyRate" class="form-label"></label>
                <input asp-for="PenaltyRate" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="PenaltyRate" class="text-danger"></span>
            </div>

            <!-- Existing PDF -->
            @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
            {
                <div class="mb-3">
                    <label class="fw-bold">Current Signed Agreement:</label>
                    <p>
                        <a class="btn btn-outline-primary btn-sm" href="/Contracts/Download/@Model.Id">
                            Download Current PDF
                        </a>
                    </p>
                </div>
            }

            <!-- Upload New PDF -->
            <div class="form-group mb-3">
                <label class="form-label">Replace Signed Agreement (PDF only)</label>
                <input type="file" name="signedAgreement" accept="application/pdf" class="form-control" />
                <small class="text-muted">Leave empty to keep the existing file.</small>
            </div>

            <!-- Submit -->
            <div class="form-group mt-3">
                <button type="submit" class="btn btn-success">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
