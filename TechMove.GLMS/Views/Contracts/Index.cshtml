@model TechMove.GLMS.Helpers.PaginatedList<TechMove.GLMS.API.Models.Contract>

@using TechMove.GLMS.API.Models.Enums

@{
    ViewData["Title"] = "Contracts";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2>Contracts</h2>
    <a class="btn btn-primary" asp-action="Create">Create New Contract</a>
</div>

<!-- FILTERS -->
<form method="get" class="row mb-4">

    <div class="col-md-3">
        <label>Start Date</label>
        <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control" />
    </div>

    <div class="col-md-3">
        <label>End Date</label>
        <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control" />
    </div>

    <div class="col-md-3">
        <label>Status</label>
        <select name="status" class="form-control">
            <option value="">-- All --</option>
            @foreach (var s in Enum.GetValues(typeof(ContractStatus)))
            {
                <option value="@s" selected="@(ViewData["Status"]?.ToString() == s.ToString())">@s</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label>Search</label>
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control" placeholder="Contract #, SLA" />
    </div>

    <div class="col-md-12 mt-3">
        <button type="submit" class="btn btn-primary">Apply Filters</button>
        <a href="/Contracts" class="btn btn-secondary">Reset</a>
    </div>

</form>

<!-- CONTRACTS TABLE -->
<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["ContractNumberSort"]"
                   asp-route-startDate="@ViewData["StartDate"]"
                   asp-route-endDate="@ViewData["EndDate"]"
                   asp-route-status="@ViewData["Status"]"
                   asp-route-search="@ViewData["Search"]">
                    Contract #
                </a>
            </th>

            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["ClientIdSort"]"
                   asp-route-startDate="@ViewData["StartDate"]"
                   asp-route-endDate="@ViewData["EndDate"]"
                   asp-route-status="@ViewData["Status"]"
                   asp-route-search="@ViewData["Search"]">
                    Client ID
                </a>
            </th>

            <th>Status</th>

            <th>
                <a asp-action="Index"
                   asp-route-sortOrder="@ViewData["StartSort"]"
                   asp-route-startDate="@ViewData["StartDate"]"
                   asp-route-endDate="@ViewData["EndDate"]"
                   asp-route-status="@ViewData["Status"]"
                   asp-route-search="@ViewData["Search"]">
                    Start Date
                </a>
            </th>

            <th>End Date</th>
            <th>Service Level</th>
            <th>Base Rate</th>
            <th>Penalty Rate</th>
            <th>PDF</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ContractNumber</td>
                <td>@item.ClientId</td>
                <td>@item.Status</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.ServiceLevel</td>
                <td>R @item.BaseRate</td>
                <td>R @item.PenaltyRate</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                    {
                        <span class="text-success fw-bold">Yes</span>
                    }
                    else
                    {
                        <span class="text-muted">No</span>
                    }
                </td>

                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>

                    @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                    {
                        <a href="/Contracts/Download/@item.Id" class="btn btn-sm btn-outline-primary">
                            PDF
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<nav>
    <ul class="pagination">

        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-sortOrder="@ViewData["SortOrder"]"
                   asp-route-startDate="@ViewData["StartDate"]"
                   asp-route-endDate="@ViewData["EndDate"]"
                   asp-route-status="@ViewData["Status"]"
                   asp-route-search="@ViewData["Search"]">
                    Previous
                </a>
            </li>
        }

        <li class="page-item disabled">
            <span class="page-link">
                Page @Model.PageIndex of @Model.TotalPages
            </span>
        </li>

        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-sortOrder="@ViewData["SortOrder"]"
                   asp-route-startDate="@ViewData["StartDate"]"
                   asp-route-endDate="@ViewData["EndDate"]"
                   asp-route-status="@ViewData["Status"]"
                   asp-route-search="@ViewData["Search"]">
                    Next
                </a>
            </li>
        }

    </ul>
</nav>
