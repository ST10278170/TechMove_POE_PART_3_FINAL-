@model TechMove.GLMS.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="text-center">

        <h2 class="text-danger mb-3">An error occurred</h2>
        <p class="text-muted">Something went wrong while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p>
                <strong>Request ID:</strong>
                <code>@Model.RequestId</code>
            </p>
        }

        <hr class="my-4" />

        <p class="text-muted">
            If this issue continues, please contact the system administrator.
        </p>

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">
            Return to Dashboard
        </a>

    </div>
</div>
