@model TechMove.GLMS.Helpers.PaginatedList<TechMove.GLMS.API.Models.ServiceRequest>


@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h2>Service Requests</h2>
    <a class="btn btn-primary" asp-action="Create">Create New Service Request</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSort"]">Request #</a>
            </th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["ContractSort"]">Contract ID</a>
            </th>

            <th>Description</th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["UsdSort"]">Cost (USD)</a>
            </th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["ZarSort"]">Cost (ZAR)</a>
            </th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["StatusSort"]">Status</a>
            </th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CreatedSort"]">Created</a>
            </th>

            <th>
                <a asp-action="Index" asp-route-sortOrder="@ViewData["CompletedSort"]">Completed</a>
            </th>

            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>

                <td>@item.ContractId</td>

                <td>@item.Description</td>

                <td>$@item.CostUSD</td>
                <td>R @item.CostZAR</td>

                <td>@item.Status</td>

                <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>

                <td>
                    @if (item.CompletedAt != null)
                    {
                        @item.CompletedAt?.ToString("yyyy-MM-dd")
                    }
                    else
                    {
                        <span class="text-muted">Pending</span>
                    }
                </td>

                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@item.Id">Details</a>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- PAGINATION -->
<nav>
    <ul class="pagination">

        @if (Model.HasPreviousPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-sortOrder="@ViewData["SortOrder"]">
                    Previous
                </a>
            </li>
        }

        <li class="page-item disabled">
            <span class="page-link">
                Page @Model.PageIndex of @Model.TotalPages
            </span>
        </li>

        @if (Model.HasNextPage)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-sortOrder="@ViewData["SortOrder"]">
                    Next
                </a>
            </li>
        }

    </ul>
</nav>
