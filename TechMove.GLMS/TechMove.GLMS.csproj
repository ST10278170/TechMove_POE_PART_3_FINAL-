<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
	</PropertyGroup>

	<ItemGroup>
		<!-- MVC only needs HttpClient + Newtonsoft for JSON -->
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
	</ItemGroup>

	<!-- Prevent auto-generated assembly attribute files from being compiled -->
	<ItemGroup>
		<Compile Remove="obj\**\*.cs" />
	</ItemGroup>
	<ItemGroup>
	  <ProjectReference Include="..\TechMove.GLMS.API\TechMove.GLMS.API.csproj" />
	</ItemGroup>

</Project>
